root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true

[*.{js,cjs,mjs,jsx,ts,tsx,css,scss}]
indent_style = tab
indent_size = 2

[*.{json,jsonc,md,yml,yaml}]
indent_style = space
indent_size = 2

[*.config.{js,cjs,mjs,ts}]
indent_style = space
indent_size = 2

[*.md]
trim_trailing_whitespace = false
